<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Portfolio</title>
    <link rel="stylesheet" href="new.css">
</head>
<body>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-text">
            <h1>Hi there, I’m <span>Samia Khan</span></h1>
            <p>Frontend Developer & Designer crafting calm digital spaces</p>
            <button>Discover My Creations</button>
        </div>

        <div class="hero-image">
            <img src="new img.jpg" alt="Profile">
        </div>
    </section>

    <!-- About -->
    <section class="about">
        <h2>About Me</h2>
        <div class="cards">
            <div class="card">
                <h3>Who I Am</h3>
                <p>A CS student passionate about building thoughtful and aesthetic digital experiences.</p>
            </div>

            <div class="card">
                <h3>What I Love</h3>
                <p>Designing, learning Java & DSA, and creating projects that feel warm and intuitive.</p>
            </div>

            <div class="card">
                <h3>Sunlight Side</h3>
                <p>I bring calm energy, creativity, and consistency into everything I build.</p>
            </div>
        </div>
    </section>

    <!-- Skills -->
    <section class="skills">
        <h2>Skills</h2>
        <div class="skill-tags">
            <span>HTML</span>
            <span>CSS</span>
            <span>Java</span>
            <span>JavaScript</span>
            <span>DSA</span>
           
        </div>
    </section>

    
               

    <!-- Contact -->
    <section class="contact">
        <h2>Let’s Bloom Together</h2>
        <form>
            <input type="text" placeholder="Your Name">
            <input type="email" placeholder="Your Email">
            <textarea placeholder="Your Message"></textarea>
            <button type="submit">Send Message</button>
        </form>
    </section>

</body>
</html>
